# ============================================================================
# Required for local dev and production
# ============================================================================

# MongoDB connection string (Atlas, self-hosted, or local).
MONGODB_URI=

# NextAuth secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=

# Public base URL of the site. Used in metadata, sitemap, and redirects.
# Local: http://localhost:3000
# Prod:  https://your-domain.com
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ============================================================================
# Optional: Google sign-in
# ============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================================
# Optional: URL safety scanning (PR 4)
# Get a free key at https://developers.google.com/safe-browsing/v4/get-started
# ============================================================================
GOOGLE_SAFE_BROWSING_API_KEY=

# ============================================================================
# Optional: Rate limiting (PR 6)
# Sign up at https://upstash.com/ for a free Redis instance.
# ============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Salt used to hash IPs before logging or persisting. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HASH_SALT=

# ============================================================================
# Optional: CAPTCHA (PR 6)
# Sign up at https://www.cloudflare.com/products/turnstile/ for a free key.
# ============================================================================
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ============================================================================
# Optional: Error tracking (PR 7)
# ============================================================================
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ============================================================================
# Optional: Abuse reports (PR 9)
# ============================================================================
ABUSE_REPORT_EMAIL=
